# 1) 开发环境私有配置（含邮箱授权码等，避免提交到远端）
backend/src/main/resources/application-dev.yml

# 2) 常见构建产物 / 依赖目录（可按需增减）
backend/target/
client/node_modules/
admin/node_modules/

# 3) IDE / 临时文件
.idea/
.vscode/
*.iml
*.log
dist/
out/

# IDE 与编辑器
.idea/
.vscode/
*.suo
*.user

# 依赖目录（不要提交）
node_modules/
admin/node_modules/
backend/node_modules/
client/node_modules/

# 构建 / 编译产物（不要提交）
client/dist/
admin/dist/
backend/target/

# 本地环境与敏感信息（不要提交）
.env
.env.local
.env.*.local
*.log
logs/

# 系统与临时文件
